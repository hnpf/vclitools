#!/bin/bash
# Description: Kills whatever process is squatting on that port.
port=$1
if [[ -z "$port" ]]; then
  echo "Usage: port-kill <port>"
  exit 1
fi
pid=$(lsof -t -i :"$port")
if [[ -n "$pid" ]]; then
  kill -9 "$pid"
  echo "Killed process $pid on port $port"
else
  echo "No process found on port $port"
fi
